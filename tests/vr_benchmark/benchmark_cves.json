{
  "_meta": {
    "description": "VR module v0.1 benchmark suite — 20 retired CVEs for validation",
    "selection_criteria": [
      "Public patch commit exists",
      "Vulnerable version downloadable or buildable",
      "Known working PoC exists (ground truth)",
      "Mix of crash types, target classes, and difficulty tiers"
    ],
    "tiers": {
      "1": "Obvious trigger — single function, clear overflow/UAF, PoC is trivial",
      "2": "Needs analysis — multi-function data flow, requires understanding the protocol/format",
      "3": "Complex — deep call chains, heap grooming, or logic bugs requiring domain expertise"
    },
    "metrics": [
      "detection_rate: root cause correctly identified (out of 20)",
      "poc_rate: working crash PoC produced (out of 20)",
      "turn_efficiency: mean turns to reach working PoC",
      "false_claims: exploitable claimed incorrectly (obligation system should catch)"
    ]
  },
