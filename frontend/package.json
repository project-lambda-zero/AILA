{
  "name": "@aila/shell",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:storybook:baseline": "test-storybook --update-snapshot",
    "honesty-audit": "node src/tools/honesty-audit.js src/ --whitelist ../honesty_whitelist.js",
    "clean": "rm -rf dist node_modules .vite"
  },
  "dependencies": {
    "@aila/forensics-frontend": "workspace:*",
    "@aila/hello-world-frontend": "workspace:*",
    "@aila/vulnerability-frontend": "workspace:*",
    "@aila/vr-frontend": "workspace:*",
    "@base-ui/react": "catalog:ui",
    "@fontsource-variable/geist": "catalog:ui",
    "@phosphor-icons/react": "catalog:ui",
    "@tailwindcss/vite": "catalog:vite",
    "@tanstack/react-query": "catalog:query",
    "@tanstack/react-table": "catalog:query",
    "@xyflow/react": "catalog:flow",
    "class-variance-authority": "catalog:ui",
    "clsx": "catalog:ui",
    "cmdk": "catalog:ui",
    "html2canvas": "catalog:data",
    "leaflet": "catalog:maps",
    "lucide-react": "catalog:ui",
    "ogl": "catalog:ui",
    "motion": "catalog:ui",
    "papaparse": "catalog:data",
    "react": "catalog:react19",
    "react-dom": "catalog:react19",
    "react-grid-layout": "catalog:data",
    "react-leaflet": "catalog:maps",
    "react-router": "catalog:router",
    "recharts": "catalog:ui",
    "shadcn": "catalog:ui",
    "sonner": "catalog:ui",
    "tailwind-merge": "catalog:tailwind",
    "tailwindcss": "catalog:tailwind",
    "tw-animate-css": "catalog:tailwind",
    "zustand": "catalog:ui"
  },
  "devDependencies": {
    "@aila/typescript-config": "workspace:*",
    "@axe-core/playwright": "catalog:testing",
    "@playwright/test": "catalog:testing",
    "@storybook/addon-a11y": "catalog:storybook",
    "@storybook/addon-themes": "catalog:storybook",
    "@storybook/react": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@storybook/test-runner": "catalog:storybook",
    "@testing-library/jest-dom": "catalog:testing",
    "@testing-library/react": "catalog:testing",
    "@testing-library/user-event": "catalog:testing",
    "@types/leaflet": "catalog:types",
    "@types/node": "catalog:types",
    "@types/papaparse": "catalog:types",
    "@types/react": "catalog:react19",
    "@types/react-dom": "catalog:react19",
    "@types/react-grid-layout": "catalog:types",
    "@vitejs/plugin-react": "catalog:vite",
    "@vitest/coverage-v8": "catalog:vite",
    "jsdom": "catalog:testing",
    "storybook": "catalog:storybook",
    "typescript": "catalog:",
