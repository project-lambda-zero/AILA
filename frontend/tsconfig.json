{
  "extends": "@aila/typescript-config/react-vite",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["src/app/*"],
      "@platform/*": ["src/platform/*"]
